<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Tuyen Sinh Dai Hoc 2026</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ScoresServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.ScoresServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ScoresServlet</servlet-name>
        <url-pattern>/scores</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>NguyenVongServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.NguyenVongServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NguyenVongServlet</servlet-name>
        <url-pattern>/nguyenvong</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddNguyenVongServlet</servlet-name>
        <servlet-class>com.tuyensinh.web.servlet.AddNguyenVongServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddNguyenVongServlet</servlet-name>
        <url-pattern>/add-nguyenvong</url-pattern>
    </servlet-mapping>

</web-app>
